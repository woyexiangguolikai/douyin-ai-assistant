{
    "name":  "douyin-ai-assistant",
    "version":  "1.0.0",
    "description":  "鎶栭煶 AI 鐩存挱鍔╂墜 鈥?瀹炴椂寮瑰箷閲囬泦 + AI 鍥炲鐢熸垚",
    "main":  "dist-electron/main.js",
    "scripts":  {
                    "dev":  "vite",
                    "build:renderer":  "vite build",
                    "build:electron":  "tsc -p tsconfig.electron.json",
                    "build":  "npm run build:renderer \u0026\u0026 npm run build:electron",
                    "start":  "npm run build \u0026\u0026 electron dist-electron/main.js",
                    "pack":  "npm run build \u0026\u0026 electron-builder --win",
                    "dist":  "npm run build \u0026\u0026 electron-builder --win --config electron-builder.yml"
                },
    "dependencies":  {
                         "lucide-react":  "^0.468.0",
                         "openai":  "^4.77.0",
                         "react":  "^18.3.1",
                         "react-dom":  "^18.3.1",
                         "ws":  "^8.18.0",
                         "playwright":  "^1.49.1",
                         "protobufjs":  "^7.4.0",
                         "sql.js":  "^1.11.0"
                     },
    "devDependencies":  {
                            "@types/node":  "^22.20.1",
                            "@types/react":  "^18.3.12",
                            "@types/react-dom":  "^18.3.1",
                            "@types/ws":  "^8.5.13",
                            "@vitejs/plugin-react":  "^4.3.4",
                            "autoprefixer":  "^10.4.20",
                            "electron":  "^33.4.11",
                            "electron-builder":  "^25.1.8",
                            "postcss":  "^8.4.49",
                            "tailwindcss":  "^3.4.17",
                            "typescript":  "^5.7.2",
                            "vite":  "^6.0.5"
                        }
}